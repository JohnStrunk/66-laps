import { Then } from '@cucumber/cucumber';
import { CustomWorld } from '../../support/world';
import { expect } from '@playwright/test';

Then('the 3D swimmers should have the corresponding color for their emoji', async function (this: CustomWorld) {
    const previousSwimmers = (this.testState as { swimmers?: import("../../../src/modules/SwimmerModel").ISwimmer[] })?.swimmers;
    expect(previousSwimmers).toBeDefined();

    const currentSwimmers = await this.page!.evaluate(() => {
        return (window as unknown as { __TEST_SWIMMERS__: import("../../../src/modules/SwimmerModel").ISwimmer[] }).__TEST_SWIMMERS__;
    });

    expect(currentSwimmers).toBeDefined();
    expect(currentSwimmers.length).toBe(previousSwimmers.length);

    // Verify that the avatars haven't changed between 2D and 3D views
    for (let i = 0; i < currentSwimmers.length; i++) {
        expect(currentSwimmers[i].avatar.emoji).toBe(previousSwimmers[i].avatar.emoji);
        expect(currentSwimmers[i].avatar.color).toBe(previousSwimmers[i].avatar.color);
    }
});
